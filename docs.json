{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Infobase",
  "description": "Upload files and scrape websites to build a knowledge base your AI agents can reference during calls.",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://oneinbox.ai"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Documentation",
            "pages": ["index"]
          }
        ]
      },
      {
        "language": "ja",
        "groups": [
          {
            "group": "ドキュメント",
            "pages": ["ja/index"]
          }
        ]
      }
    ]
  }
}
