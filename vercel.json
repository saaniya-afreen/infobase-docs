{
  "version": 2,
  "builds": [{ "src": "package.json", "use": "@vercel/static" }],
  "routes": [
    { "src": "/_mintlify/(.*)", "dest": "https://oneinbox.mintlify.app/_mintlify/$1" },
    { "src": "/api/request", "dest": "https://oneinbox.mintlify.app/_mintlify/api/request" },
    { "src": "/llms.txt", "dest": "https://oneinbox.mintlify.app/llms.txt" },
    { "src": "/llms-full.txt", "dest": "https://oneinbox.mintlify.app/llms-full.txt" },
    { "src": "/sitemap.xml", "dest": "https://oneinbox.mintlify.app/sitemap.xml" },
    { "src": "/robots.txt", "dest": "https://oneinbox.mintlify.app/robots.txt" },
    { "src": "/mcp", "dest": "https://oneinbox.mintlify.app/mcp" },
    { "src": "/mintlify-assets/(.*)", "dest": "https://oneinbox.mintlify.app/mintlify-assets/$1" },
    { "src": "/(.*)", "dest": "https://oneinbox.mintlify.app/$1" }
  ]
}
